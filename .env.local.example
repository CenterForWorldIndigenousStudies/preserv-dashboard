MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=cwis_preservation
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password

# Storybook URL (used by /developers/component-library in production)
STORYBOOK_URL=https://your-storybook.vercel.app

# Auth.js v5 / Google OAuth (required for sign-in)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_URL=http://localhost:3000
AUTH_SECRET=generate-a-32-char-random-string
