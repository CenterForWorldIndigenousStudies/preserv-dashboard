{
  "name": "cwis-preservation-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "run-s db:prisma:generate build:next",
    "build:next": "next build",
    "db:prisma:generate": "prisma generate --schema=./lib/prisma/schema.prisma",
    "db:prisma:pull": "prisma db pull --schema=./lib/prisma/schema.prisma --force",
    "db:prisma:studio": "prisma studio",
    "dev": "run-p dev:next storybook",
    "dev:next": "next dev",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "run-p lint:project lint:markdown",
    "lint:markdown": "markdownlint-cli2 '**/*.md'",
    "lint:project": "eslint './**/*.{ts,tsx}' --max-warnings=0 --cache --cache-location .eslintcache",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build --quiet --output-dir ./storybook-static",
    "storybook:clean": "rm -rf storybook-static",
    "storybook:preview": "storybook preview -p 6006 --storybook-dir ./storybook-static",
    "test": "run-s test:unit test:integration",
    "test:all": "npm run test",
    "test:unit": "vitest run --project unit tests/unit",
    "test:unit:watch": "vitest --project unit tests/unit",
    "test:coverage": "vitest run --project unit tests/unit --coverage",
    "test:integration": "vitest run --project integration tests/integration",
    "test:storybook": "vitest run --project storybook",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mui/material": "^9.0.0",
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "mariadb": "^3.5.2",
    "material-react-table": "^3.2.1",
    "mermaid": "^11.14.0",
    "mysql2": "^3.14.1",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.31",
    "playwright": "^1.59.1",
    "prisma": "^7.7.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-storybook": "^10.3.5",
    "markdownlint-cli2": "0.22.0",
    "next-router-mock": "^1.0.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "prettier": "3.8.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "24"
  }
}
