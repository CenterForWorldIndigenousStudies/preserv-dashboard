generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model access_levels {
  id              String            @id @db.VarChar(36)
  level_name      String            @unique(map: "unique_level_name") @db.VarChar(50)
  description     String?           @db.Text
  created_at      DateTime?         @default(now()) @db.DateTime(0)
  updated_at      DateTime?         @default(now()) @db.DateTime(0)
  document_access document_access[]
}

model authors {
  id                  String                @id @db.VarChar(36)
  name                String                @unique(map: "unique_author_name") @db.VarChar(255)
  created_at          DateTime?             @default(now()) @db.DateTime(0)
  updated_at          DateTime?             @default(now()) @db.DateTime(0)
  document_to_authors document_to_authors[]
}

model batches {
  id                           String                @id @db.VarChar(36)
  name                         String                @db.VarChar(255)
  binary_processing_datetime   DateTime?             @db.DateTime(0)
  total_files                  Int?                  @default(0)
  unique_files                 Int?                  @default(0)
  duplicate_files              Int?                  @default(0)
  inter_duplicates             Int?                  @default(0)
  intra_duplicates             Int?                  @default(0)
  exact_duplicates_found       Int?                  @default(0)
  total_duplicates_found       Int?                  @default(0)
  cost_saved                   Decimal?              @default(0.00) @db.Decimal(10, 2)
  cost                         Decimal?              @default(0.00) @db.Decimal(10, 2)
  processing_time_seconds      Int?                  @default(0)
  total_cost                   Decimal?              @default(0.00) @db.Decimal(10, 2)
  registry_version             String?               @db.VarChar(50)
  dedup_method                 String?               @db.VarChar(100)
  started_at                   DateTime?             @db.DateTime(0)
  completed_at                 DateTime?             @db.DateTime(0)
  started_by                   String?               @db.VarChar(255)
  processing_details           String?               @db.LongText
  duplicates_removed_timestamp DateTime?             @db.DateTime(0)
  error_count                  Int?                  @default(0)
  files_processed              Int?                  @default(0)
  last_processed               DateTime?             @db.DateTime(0)
  status                       String?               @db.VarChar(50)
  document_to_batches          document_to_batches[]

  @@index([binary_processing_datetime], map: "idx_binary_processing_datetime")
  @@index([name], map: "idx_name")
}

model document_access {
  id              String        @id @db.VarChar(36)
  document_id     String        @db.VarChar(36)
  access_level_id String        @db.VarChar(36)
  granted_by      String?       @db.VarChar(255)
  granted_at      DateTime?     @default(now()) @db.DateTime(0)
  documents       documents     @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_document_access_doc")
  access_levels   access_levels @relation(fields: [access_level_id], references: [id], onUpdate: Restrict, map: "fk_document_access_level")

  @@index([access_level_id], map: "idx_access_level_id")
  @@index([document_id], map: "idx_document_id")
}

model document_quality {
  id                   String                                @id @db.VarChar(36)
  document_id          String                                @unique(map: "unique_document_quality") @db.VarChar(36)
  page_count           Int?
  validation_type      document_quality_validation_type?
  validation_status    document_quality_validation_status?
  validator            String?                               @db.VarChar(255)
  validation_timestamp DateTime?                             @db.DateTime(0)
  access_level         String?                               @db.VarChar(50)
  content_duplication  document_quality_content_duplication?
  final_status         String?                               @db.VarChar(36)
  created_at           DateTime?                             @default(now()) @db.DateTime(0)
  updated_at           DateTime?                             @default(now()) @db.DateTime(0)
  documents            documents                             @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_doc_quality_doc")
  state_history        state_history?                        @relation(fields: [final_status], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_doc_quality_state")

  @@index([final_status], map: "final_status")
}

model document_to_authors {
  id               String                                @id @db.VarChar(36)
  document_id      String                                @db.VarChar(36)
  author_id        String                                @db.VarChar(36)
  contributor_type document_to_authors_contributor_type?
  created_at       DateTime?                             @default(now()) @db.DateTime(0)
  updated_at       DateTime?                             @default(now()) @db.DateTime(0)
  documents        documents                             @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dta_doc")
  authors          authors                               @relation(fields: [author_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dta_author")

  @@unique([document_id, author_id], map: "unique_doc_author")
  @@index([author_id], map: "idx_author_id")
}

model document_to_batches {
  id                      String    @id @db.VarChar(36)
  document_id             String    @db.VarChar(36)
  batch_id                String    @db.VarChar(36)
  added_at                DateTime? @default(now()) @db.DateTime(0)
  cost                    Decimal?  @default(0.00) @db.Decimal(10, 2)
  processing_time_seconds Int?      @default(0)
  documents               documents @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtb_doc")
  batches                 batches   @relation(fields: [batch_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtb_batch")

  @@unique([document_id, batch_id], map: "unique_doc_batch")
  @@index([batch_id], map: "idx_batch_id")
}

model document_to_metadata {
  id                String                           @id @db.VarChar(36)
  document_id       String                           @db.VarChar(36)
  metadata_field_id String                           @db.VarChar(36)
  value             String?                          @db.LongText
  value_type        document_to_metadata_value_type? @default(string)
  created_at        DateTime?                        @default(now()) @db.DateTime(0)
  updated_at        DateTime?                        @default(now()) @db.DateTime(0)
  documents         documents                        @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtm_doc")
  metadata          metadata                         @relation(fields: [metadata_field_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtm_meta")

  @@unique([document_id, metadata_field_id], map: "unique_doc_field")
  @@index([metadata_field_id], map: "idx_metadata_field_id")
}

model document_to_publishers {
  id           String     @id @db.VarChar(36)
  document_id  String     @db.VarChar(36)
  publisher_id String     @db.VarChar(36)
  created_at   DateTime?  @default(now()) @db.DateTime(0)
  updated_at   DateTime?  @default(now()) @db.DateTime(0)
  documents    documents  @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtp_doc")
  publishers   publishers @relation(fields: [publisher_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtp_pub")

  @@unique([document_id, publisher_id], map: "unique_doc_publisher")
  @@index([publisher_id], map: "idx_publisher_id")
}

model document_to_tags {
  id          String    @id @db.VarChar(36)
  document_id String    @db.VarChar(36)
  tag_id      String    @db.VarChar(36)
  created_at  DateTime? @default(now()) @db.DateTime(0)
  documents   documents @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtt_doc")
  tags        tags      @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dtt_tag")

  @@unique([document_id, tag_id], map: "unique_doc_tag")
  @@index([tag_id], map: "idx_tag_id")
}

model document_versions {
  id                    String    @id @db.VarChar(36)
  document_id           String    @db.VarChar(36)
  canonical_document_id String    @db.VarChar(36)
  hash_content          String?   @db.VarChar(64)
  comments              String?   @db.Text
  changes_summary       String?   @db.Text
  created_at            DateTime? @default(now()) @db.DateTime(0)
  updated_at            DateTime? @default(now()) @db.DateTime(0)
  doc                   documents @relation("DocumentId", fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dv_doc")
  canonical             documents @relation("CanonicalDocumentId", fields: [canonical_document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_dv_canonical")

  @@index([document_id], map: "document_id")
  @@index([canonical_document_id], map: "idx_canonical_document_id")
}

model documents {
  id             String             @id @db.VarChar(36)
  original_url   String?            @db.Text
  source_id      String?            @db.VarChar(255)
  filename       String             @db.VarChar(255)
  filetype       String?            @db.VarChar(100)
  filesize       BigInt?
  hash_binary    String?            @db.VarChar(64)
  hash_content   String?            @db.VarChar(64)
  created_at     DateTime?          @default(now()) @db.DateTime(0)
  updated_at     DateTime?          @default(now()) @db.DateTime(0)
  document_access         document_access[]
  document_quality        document_quality?
  document_to_authors    document_to_authors[]
  document_to_batches    document_to_batches[]
  document_to_metadata   document_to_metadata[]
  document_to_publishers document_to_publishers[]
  document_to_tags       document_to_tags[]
  doc_versions           document_versions[] @relation("DocumentId")
  canonical_versions     document_versions[] @relation("CanonicalDocumentId")
  state_history          state_history[]
  version_groups_canonical version_groups[] @relation("VersionGroupsCanonical")
  version_groups_document version_groups[] @relation("VersionGroupsDocument")

  @@index([filetype], map: "idx_filetype")
  @@index([hash_binary], map: "idx_hash_binary")
  @@index([hash_content], map: "idx_hash_content")
  @@index([source_id], map: "idx_source_id")
}

model edit_history {
  id             String    @id @db.VarChar(36)
  entity_id      String    @db.VarChar(36)
  entity_table   String    @db.VarChar(100)
  previous_value String?   @db.Text
  new_value      String?   @db.Text
  editor_email   String?   @db.VarChar(255)
  edit_summary   String?   @db.VarChar(500)
  edited_at      DateTime? @default(now()) @db.DateTime(0)

  @@index([edited_at], map: "idx_edited_at")
  @@index([entity_table, entity_id], map: "idx_entity")
}

model metadata {
  id                   String                 @id @db.VarChar(36)
  name                 String                 @unique(map: "unique_name") @db.VarChar(100)
  notes                String?                @db.Text
  created_at           DateTime?              @default(now()) @db.DateTime(0)
  updated_at           DateTime?              @default(now()) @db.DateTime(0)
  document_to_metadata document_to_metadata[]
}

model publishers {
  id                     String                   @id @db.VarChar(36)
  name                   String                   @unique(map: "unique_publisher_name") @db.VarChar(255)
  created_at             DateTime?                @default(now()) @db.DateTime(0)
  updated_at             DateTime?                @default(now()) @db.DateTime(0)
  document_to_publishers document_to_publishers[]
}

model state_history {
  id               String             @id @db.VarChar(36)
  document_id      String             @db.VarChar(36)
  previous_state   String?            @db.VarChar(50)
  new_state        String             @db.VarChar(50)
  changed_at       DateTime?          @default(now()) @db.DateTime(0)
  document_quality document_quality[]
  documents        documents          @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_sh_doc")

  @@index([changed_at], map: "idx_changed_at")
  @@index([document_id], map: "idx_document_id")
  @@index([new_state], map: "idx_new_state")
}

model tags {
  id               String             @id @db.VarChar(36)
  name             String             @unique(map: "unique_tag_name") @db.VarChar(100)
  created_at       DateTime?          @default(now()) @db.DateTime(0)
  updated_at       DateTime?          @default(now()) @db.DateTime(0)
  document_to_tags document_to_tags[]
}

model version_groups {
  id                    String    @id @db.VarChar(36)
  group_id              String    @db.VarChar(36)
  canonical_document_id String    @db.VarChar(36)
  document_id           String    @db.VarChar(36)
  hash_content          String?   @db.VarChar(64)
  notes                 String?   @db.Text
  created_at            DateTime? @default(now()) @db.DateTime(0)
  updated_at            DateTime? @default(now()) @db.DateTime(0)
  canonical_doc         documents @relation("VersionGroupsCanonical", fields: [canonical_document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_vg_canonical")
  doc                   documents @relation("VersionGroupsDocument", fields: [document_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_vg_doc")

  @@index([canonical_document_id], map: "canonical_document_id")
  @@index([document_id], map: "document_id")
  @@index([group_id], map: "idx_group_id")
}

enum document_quality_validation_type {
  AI_ONLY
  AI_WITH_HUMAN_REVIEW
  HUMAN_ONLY
}

enum document_to_authors_contributor_type {
  PRIMARY
  SECONDARY
  TERTIARY
}

enum document_quality_validation_status {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum document_to_metadata_value_type {
  string
  int
  float
  boolean
  json
}

enum document_quality_content_duplication {
  EXACT_DUPLICATE
  UNIQUE
}
